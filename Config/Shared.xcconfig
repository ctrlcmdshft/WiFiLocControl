// Shared.xcconfig
// Minimal shared configuration
// All other settings use Xcode project defaults

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = WiFiLocControl
PRODUCT_DISPLAY_NAME = WiFiLocControl
PRODUCT_BUNDLE_IDENTIFIER = com.github.wifiloccontrol.app
MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1

// ==========================================
// Platform Configuration
// ==========================================
MACOSX_DEPLOYMENT_TARGET = 26.0

// ==========================================
// Info PLIST
// ==========================================
GENERATE_INFOPLIST_FILE = YES

// ==========================================
// Entitlements
// ==========================================
CODE_SIGN_ENTITLEMENTS = Config/WiFiLocControlApp.entitlements
ALWAYS_SEARCH_USER_PATHS = NO
